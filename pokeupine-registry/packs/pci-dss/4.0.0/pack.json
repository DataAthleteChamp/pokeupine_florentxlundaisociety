    {
      "id": "PCI-DSS-8.3.6",
      "title": "Passwords/passphrases meet minimum complexity requirements",
      "clause_text": "If passwords/passphrases are used as an authentication factor, they meet the following minimum level of complexity: A minimum length of 12 characters (or if the system does not support 12 characters, a minimum length of eight characters). Contain both numeric and alphabetic characters.",
      "requirement": "Set minimum password length to 12 or greater.",
      "severity": "medium",
      "provenance": {
