  "tests": [
    {
      "id": "PCI-DSS-3.3.1::no-sad-storage",
      "control_id": "PCI-DSS-3.3.1",
      "kind": "dataflow",
      "spec": {
        "sources": {
          "sad_field": [
            {
              "kind": "pydantic_field",
              "class_in": [
                "Order",
                "Payment",
                "Card",
                "Transaction"
              ],
              "field_name_regex": "^(cvv|cvc|cvv2|csc)$"
            }
          ]
        },
        "sinks": {
          "storage": [
            {
              "kind": "call",
              "qualified_name_regex": "(db|session|cursor)\\.execute"
            },
            {
              "kind": "call",
              "qualified_name_regex": "\\.save\\("
            }
          ]
        },
        "sanitizers": []
      },
      "target_globs": [
        "**/*.py"
      ]
    },
    {
      "id": "PCI-DSS-3.5.1::pan-unreadable",
      "control_id": "PCI-DSS-3.5.1",
      "kind": "dataflow",
      "spec": {
        "sources": {
          "pan_typed": [
            {
              "kind": "pydantic_field",
              "class_in": [
                "Order",
                "Payment",
                "Card",
                "Transaction"
              ],
              "field_name_regex": "^(card_number|pan|cc(_num)?)$"
            }
          ]
        },
        "sinks": {
          "storage": [
            {
              "kind": "call",
              "qualified_name_regex": "(db|session|cursor)\\.execute"
            },
            {
              "kind": "call",
              "qualified_name_regex": "\\.save\\("
            }
          ]
        },
        "sanitizers": [
          {
            "kind": "call",
            "qualified_name_regex": "^(tokenize|vault\\.store|mask_pan)$"
          }
        ]
      },
      "target_globs": [
        "**/*.py"
      ]
    },
    {
      "id": "PCI-DSS-4.2.1::strong-crypto-transit",
      "control_id": "PCI-DSS-4.2.1",
      "kind": "ast_check",
      "spec": {
        "check_type": "cleartext_http"
      },
      "target_globs": [
        "**/*.py"
      ]
    },
    {
      "id": "PCI-DSS-8.3.6::password-length",
      "control_id": "PCI-DSS-8.3.6",
      "kind": "ast_check",
      "spec": {
        "check_type": "weak_password_policy"
      },
      "target_globs": [
        "**/*.py"
      ]
    },
    {
      "id": "PCI-DSS-10.2.1::audit-log-required",
      "control_id": "PCI-DSS-10.2.1",
      "kind": "decorator_required",
      "spec": {
        "required_decorator": "audit_log",
        "target_decorator_regex": "@app\\.(post|put|patch|delete)",
        "target_param_type": ""
      },
      "target_globs": [
        "**/*.py"
      ]
    },
    {
      "id": "PCI-DSS-6.2.4::sast-in-ci",
      "control_id": "PCI-DSS-6.2.4",
      "kind": "llm_judge",
      "spec": {
        "check_type": "file_exists",
        "required_files": [
          "SECURITY.md"
        ],
        "description": "code review process",
        "remediation": "Create a SECURITY.md documenting your SAST/code review process."
      },
      "target_globs": [
        "**/*.py"
      ]
    }
  ]
}