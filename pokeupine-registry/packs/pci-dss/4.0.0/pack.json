    {
      "id": "PCI-DSS-10.2.1",
      "title": "Audit logs capture all individual user access to cardholder data",
      "clause_text": "Audit logs are enabled and active for all system components. All individual user accesses to cardholder data are logged. All actions taken by any individual with root or administrative privileges are logged.",
      "requirement": "Add audit logging to all functions handling cardholder data.",
      "severity": "high",
